# ================================
# ShasanSetu Environment Variables
# ================================

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://[your-region].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2 (Private Bucket with Signed URLs)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Application
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Developer Portal (custom-forms management — separate app on port 3002)
# PORTAL_USERS: comma-separated "username:bcryptHash" pairs (1-3 dev accounts).
#   Generate a hash:  node -e "console.log(require('bcrypt').hashSync('yourpassword', 10))"
#   Example:          PORTAL_USERS=dev1:$2b$10$abc...,dev2:$2b$10$xyz...
PORTAL_USERS=nilesh:$2b$10$kyb6Zj.hSytdvdw8KG6QWOsXztqdijgiFNKT5dKz5cvMmeb4cYL02
PORTAL_JWT_SECRET=another-long-random-secret-for-the-portal-min-32-chars
PORTAL_TOKEN_EXPIRES_IN=7d
PORTAL_URL=http://localhost:3002
# Frontend (web + portal): backend base URL used by Next.js rewrites
NEXT_PUBLIC_API_URL=http://localhost:3001

# Firebase Admin SDK (Backend — for forgot-password OTP verification)
# Option A: paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: individual fields (used if JSON var is not set)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (Frontend — for sending phone OTP)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
